---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQSection from '../../components/FAQSection.astro';
import MultiSourceRating from '../../components/MultiSourceRating.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const listings = await getCollection('listings');
  return listings.map((l) => ({
    params: { slug: l.id },
    props: { listing: l },
  }));
}

const { listing } = Astro.props;
const d = listing.data;
const { Content } = await render(listing);

// Lookup the region for this listing's city to enrich PostalAddress
const allCities = await getCollection('cities');
const cityRecord = allCities.find(c => c.data.id === d.city || c.data.name_th === d.city);
const addressRegion = cityRecord?.data.region_th || null;

const categoryLabel: Record<string, string> = {
  por1: 'เตรียมสอบเข้า ป.1',
  mor1: 'เตรียมสอบเข้า ม.1',
  mor4: 'เตรียมสอบเข้า ม.4',
  uni: 'เตรียมสอบเข้ามหาวิทยาลัย',
  all: 'ทุกระดับ',
};

const tierLabel = { budget: 'งบประหยัด', mid: 'งบกลาง', premium: 'พรีเมียม' }[d.pricing_tier];
const formatLabel: Record<string, string> = {
  in_person: 'พบหน้า', online: 'ออนไลน์', hybrid: 'Hybrid',
};

// LocalBusiness schema — use EducationalOrganization subtype for richer
// education-vertical signals (Course/Service nested below)
const subjectLabels: Record<string, string> = {
  math: 'คณิตศาสตร์', science: 'วิทยาศาสตร์', physics: 'ฟิสิกส์',
  chemistry: 'เคมี', biology: 'ชีววิทยา', english: 'ภาษาอังกฤษ',
  thai: 'ภาษาไทย', social: 'สังคมศึกษา', iq: 'IQ/EQ', readiness: 'เตรียมความพร้อม',
  sat: 'SAT', ielts: 'IELTS', toefl: 'TOEFL',
};
const knowsAbout = [
  ...d.categories.map(c => categoryLabel[c] || c),
  ...d.subjects.map(s => subjectLabels[s] || s),
  ...d.target_schools,
].filter(Boolean);

const listingSchema: any = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'EducationalOrganization'],
  '@id': `https://${Astro.site?.host}/listing/${listing.id}/`,
  name: d.name_th,
  ...(d.name_en ? { alternateName: d.name_en } : {}),
  description: d.description_th,
  address: {
    '@type': 'PostalAddress',
    streetAddress: d.address_th,
    addressLocality: d.city,
    ...(addressRegion ? { addressRegion } : {}),
    addressCountry: 'TH',
  },
  ...(d.lat && d.lng ? { geo: { '@type': 'GeoCoordinates', latitude: d.lat, longitude: d.lng } } : {}),
  ...(d.phone.length > 0 ? { telephone: d.phone[0] } : {}),
  ...(d.website ? { url: d.website } : {}),
  ...(d.email ? { email: d.email } : {}),
  ...(d.founded_year ? { foundingDate: `${d.founded_year}` } : {}),
  priceRange: { budget: '฿', mid: '฿฿', premium: '฿฿฿' }[d.pricing_tier],
  knowsAbout,
  areaServed: {
    '@type': 'City',
    name: d.city,
    ...(d.district ? { containedInPlace: { '@type': 'AdministrativeArea', name: d.district } } : {}),
  },
  ...(d.google_rating ? {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: d.google_rating,
      reviewCount: d.google_review_count || 0,
      bestRating: 5,
      worstRating: 1,
    },
  } : {}),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: `คอร์สเรียนของ ${d.name_th}`,
    itemListElement: d.categories.map((c) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Course',
        name: `${categoryLabel[c] || c} โดย ${d.name_th}`,
        description: `คอร์สเรียน${categoryLabel[c] || c}กับ ${d.name_th} ${d.district ? `ที่ ${d.district}` : ''} ${d.city}`,
        provider: { '@id': `https://${Astro.site?.host}/listing/${listing.id}/` },
        inLanguage: 'th',
        educationalLevel: c === 'por1' ? 'ป.1' : c === 'mor1' ? 'ม.1' : c === 'mor4' ? 'ม.4' : c === 'uni' ? 'อุดมศึกษา' : 'ทุกระดับ',
        hasCourseInstance: {
          '@type': 'CourseInstance',
          courseMode: d.quick_facts.format.includes('online') ? 'Online' : d.quick_facts.format.includes('hybrid') ? 'Blended' : 'Onsite',
          inLanguage: 'th',
        },
      },
    })),
  },
};

const contactMissing = d.phone.length === 0 && !d.website && !d.line_id && !d.email;

// Add hasMap (Google Maps URL constructed from lat/lng) for local SEO
const googleMapsUrl = d.lat && d.lng
  ? `https://www.google.com/maps/search/?api=1&query=${d.lat},${d.lng}`
  : null;
if (googleMapsUrl) listingSchema.hasMap = googleMapsUrl;

// sameAs — external entities representing this business
const sameAs: string[] = [];
if (d.facebook_url) sameAs.push(d.facebook_url);
if (googleMapsUrl) sameAs.push(googleMapsUrl);
if (sameAs.length) listingSchema.sameAs = sameAs;

// Related listings — same category AND (same city OR shared school), top 4 by rating
const allListings = await getCollection('listings');
const related = allListings
  .filter(o => o.id !== listing.id)
  .filter(o => {
    const sharedCat = o.data.categories.some(c => d.categories.includes(c));
    if (!sharedCat) return false;
    const sameCity = o.data.city === d.city;
    const sharedSchool = o.data.target_schools.some(s => d.target_schools.includes(s));
    return sameCity || sharedSchool;
  })
  .sort((a, b) => (b.data.google_rating || 0) - (a.data.google_rating || 0))
  .slice(0, 4);
const sourceLabel: Record<string, string> = {
  apify_google_maps: 'Google Maps',
  openai_enrichment: 'ทีมงานติดฝัน (เรียบเรียง)',
  manual: 'ทีมงานติดฝัน',
  moe_registry: 'กระทรวงศึกษาธิการ',
  facebook: 'Facebook Pages',
};
const displaySources = [...new Set(d.sources.map(s => sourceLabel[s] || s))];

// Speakable schema (AEO)
const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'SpeakableSpecification',
  cssSelector: ['.speakable-1', '.speakable-2', '.speakable-3'],
};

// FAQPage
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: d.faq.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<BaseLayout
  title={`${d.name_th} — รีวิว ราคา คอร์ส | ติดฝัน`}
  description={d.description_th.slice(0, 155)}
>
  <script type="application/ld+json" set:html={JSON.stringify(listingSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[
      { label: categoryLabel[d.categories[0]] || 'ข้อมูลทั่วไป', href: `/category/${d.categories[0]}/` },
      { label: d.name_th },
    ]} />

    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
        <div class="flex-1 min-w-0">
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">{d.name_th}</h1>
          {d.name_en && <p class="text-gray-500">{d.name_en}</p>}
          <p class="text-sm text-gray-600 mt-1">{d.district ? `${d.district} · ` : ''}{d.city}</p>
        </div>
        <div class="flex flex-col items-end gap-2">
          {d.featured && <span class="text-xs px-2.5 py-1 bg-amber-100 text-amber-800 rounded-full font-semibold">★ Featured</span>}
          {d.claimed ? (
            <span class="text-xs px-2.5 py-1 bg-green-100 text-green-700 rounded-full font-medium">✓ ยืนยันแล้ว</span>
          ) : (
            <a href="/claim/" class="text-xs px-2.5 py-1 bg-gray-100 text-gray-600 rounded-full hover:bg-indigo-100 hover:text-indigo-700 transition-colors">เป็นเจ้าของ? เคลมสถาบันนี้</a>
          )}
        </div>
      </div>
      {d.google_rating && (
        <div class="flex items-center gap-2 text-sm">
          <span class="text-amber-500 text-lg">★★★★★</span>
          <span class="font-semibold text-gray-900">{d.google_rating.toFixed(1)}</span>
          {d.google_review_count && <span class="text-gray-500">({d.google_review_count} รีวิวจาก Google)</span>}
        </div>
      )}
    </header>

    <!-- Quick Facts -->
    <section class="mb-8 grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-3">
        <p class="text-xs text-indigo-600 font-medium mb-1">ราคา</p>
        <p class="text-sm font-bold text-gray-900">{d.quick_facts.price_range}</p>
      </div>
      <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-3">
        <p class="text-xs text-indigo-600 font-medium mb-1">ห้องเรียน</p>
        <p class="text-sm font-bold text-gray-900">{d.quick_facts.class_size}</p>
      </div>
      <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-3">
        <p class="text-xs text-indigo-600 font-medium mb-1">รูปแบบ</p>
        <p class="text-sm font-bold text-gray-900">{d.quick_facts.format.map(f => formatLabel[f] || f).join(', ')}</p>
      </div>
      <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-3">
        <p class="text-xs text-indigo-600 font-medium mb-1">ช่วงอายุ</p>
        <p class="text-sm font-bold text-gray-900">{d.quick_facts.age_range}</p>
      </div>
    </section>

    <!-- Description -->
    <section class="mb-8">
      <h2 class="text-xl font-bold text-gray-900 mb-3">เกี่ยวกับ {d.name_th}</h2>
      <p class="text-gray-700 leading-relaxed">{d.description_th}</p>
    </section>

    <MultiSourceRating ratings={d.multi_source_ratings} google_rating={d.google_rating} google_review_count={d.google_review_count} />

    <!-- Speakable AEO paragraphs -->
    <section class="mb-8 bg-gradient-to-br from-amber-50 to-orange-50 border border-amber-200 rounded-xl p-6">
      <h2 class="text-lg font-bold text-amber-900 mb-3">สรุปสั้นๆ</h2>
      <div class="space-y-3 text-gray-800">
        <p class="speakable-1 leading-relaxed">{d.speakable_th[0]}</p>
        <p class="speakable-2 leading-relaxed">{d.speakable_th[1]}</p>
        <p class="speakable-3 leading-relaxed">{d.speakable_th[2]}</p>
      </div>
    </section>

    <!-- Coverage -->
    <section class="mb-8 grid md:grid-cols-2 gap-6">
      <div>
        <h3 class="font-bold text-gray-900 mb-3">เตรียมสอบสำหรับ</h3>
        <div class="flex flex-wrap gap-2">
          {d.categories.map(c => (
            <a href={`/category/${c}/`} class="text-sm px-3 py-1 bg-indigo-100 text-indigo-700 rounded-full hover:bg-indigo-200 transition-colors">{categoryLabel[c]}</a>
          ))}
        </div>
      </div>
      <div>
        <h3 class="font-bold text-gray-900 mb-3">วิชาที่สอน</h3>
        <div class="flex flex-wrap gap-2">
          {d.subjects.map(s => (
            <a href={`/subject/${s}/`} class="text-sm px-3 py-1 bg-gray-100 text-gray-700 rounded-full hover:bg-gray-200 transition-colors">{s}</a>
          ))}
        </div>
      </div>
    </section>

    {d.target_schools.length > 0 && (
      <section class="mb-8">
        <h3 class="font-bold text-gray-900 mb-3">เตรียมสอบเข้าโรงเรียน</h3>
        <div class="flex flex-wrap gap-2">
          {d.target_schools.map(s => (
            <a href={`/for-school/${s}/`} class="text-sm px-3 py-1 bg-purple-100 text-purple-700 rounded-full hover:bg-purple-200 transition-colors">{s}</a>
          ))}
        </div>
      </section>
    )}

    <!-- Contact -->
    <section class="mb-8 bg-gray-50 border border-gray-200 rounded-xl p-6">
      <h2 class="text-xl font-bold text-gray-900 mb-4">ติดต่อ {d.name_th}</h2>
      <div class="space-y-2 text-sm">
        {d.address_th && <p><strong class="text-gray-700">ที่อยู่:</strong> {d.address_th}</p>}
        {d.phone.length > 0 && <p><strong class="text-gray-700">โทร:</strong> {d.phone.join(', ')}</p>}
        {d.line_id && <p><strong class="text-gray-700">LINE:</strong> {d.line_id}</p>}
        {d.facebook_url && <p><strong class="text-gray-700">Facebook:</strong> <a href={d.facebook_url} class="text-indigo-600 hover:underline" rel="noopener">{d.facebook_url}</a></p>}
        {d.website && <p><strong class="text-gray-700">เว็บไซต์:</strong> <a href={d.website} class="text-indigo-600 hover:underline" rel="noopener">{d.website}</a></p>}
        {d.email && <p><strong class="text-gray-700">Email:</strong> {d.email}</p>}
      </div>
      <p class="text-xs text-gray-500 mt-4">ติดต่อสถาบันโดยตรงผ่านช่องทางด้านบน ติดฝันไม่เป็นตัวกลางในการสมัครเรียนหรือชำระเงิน · ค่าเรียนที่แสดงเป็นการประมาณการเบื้องต้นโดยทีมงาน และอาจไม่ตรงกับราคาจริง — โปรดติดต่อสถาบันเพื่อยืนยันราคาและรายละเอียดคอร์ส</p>
    </section>

    {contactMissing && (
      <section class="mb-8 bg-amber-50 border border-amber-200 rounded-xl p-5">
        <p class="text-sm text-amber-900"><strong>ข้อมูลติดต่อยังไม่สมบูรณ์</strong> — เราอยู่ระหว่างยืนยันช่องทางติดต่อโดยตรงกับสถาบัน หากคุณเป็นเจ้าของหรือมีข้อมูลเพิ่มเติม <a href="/claim/" class="text-amber-700 hover:underline font-medium">ช่วยอัปเดตให้เราได้</a></p>
      </section>
    )}

    <!-- Markdown body content -->
    <section class="prose max-w-none mb-8">
      <Content />
    </section>

    <FAQSection items={d.faq} title={`คำถามที่พบบ่อยเกี่ยวกับ ${d.name_th}`} />

    {related.length > 0 && (
      <section class="my-10">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">สถาบันใกล้เคียงที่เทียบเคียงได้</h2>
        <p class="text-gray-600 mb-6 text-sm">รวมสถาบันที่เตรียมสอบ{categoryLabel[d.categories[0]] || ''}{d.city ? ` ใน ${d.city}` : ''} เผื่อเปรียบเทียบ</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {related.map(r => (
            <a href={`/listing/${r.id}/`} class="block bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md hover:border-indigo-300 transition-all group">
              <h3 class="font-bold text-gray-900 group-hover:text-indigo-600 transition-colors line-clamp-1">{r.data.name_th}</h3>
              <p class="text-xs text-gray-500 mt-1">{r.data.district ? `${r.data.district} · ` : ''}{r.data.city}</p>
              {r.data.google_rating && (
                <p class="text-xs text-amber-600 mt-1">★ {r.data.google_rating.toFixed(1)} ({r.data.google_review_count || 0})</p>
              )}
              <p class="text-xs text-gray-600 mt-2 line-clamp-2">{r.data.description_th.slice(0, 100)}...</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Anti-thin / Trust footer -->
    <section class="my-8 text-xs text-gray-500 border-t border-gray-200 pt-4">
      <p>ข้อมูลอัปเดตล่าสุด: {d.data_freshness_date.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      <p>แหล่งข้อมูล: {displaySources.join(', ')} · <a href="/editorial-standards/" class="text-indigo-600 hover:underline">มาตรฐานบรรณาธิการ</a></p>
      {!d.claimed && (
        <p class="mt-2">หากเป็นเจ้าของสถาบันนี้ <a href="/claim/" class="text-indigo-600 hover:underline">เคลมเพื่อปรับปรุงข้อมูล</a></p>
      )}
    </section>
  </div>
</BaseLayout>
