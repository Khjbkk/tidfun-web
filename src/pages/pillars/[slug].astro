---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pillars = await getCollection('pillars');
  return pillars.map((p) => ({
    params: { slug: p.id },
    props: { pillar: p },
  }));
}

const { pillar } = Astro.props;
const { Content } = await render(pillar);
const d = pillar.data;

// Pillar → relevant listings widget (commercial-intent funnel from informational content)
const pillarToFilter: Record<string, (l: any) => boolean> = {
  'how-to-prepare-por1-complete-guide': l => l.data.categories.includes('por1'),
  'how-to-prepare-mor1-complete-guide': l => l.data.categories.includes('mor1'),
  'how-to-prepare-mor4-complete-guide': l => l.data.categories.includes('mor4'),
  'how-to-prepare-tcas-tgat-tpat': l => l.data.categories.includes('uni'),
  'english-program-ep-bilingual-thailand': l => l.data.subjects.includes('english'),
  'online-vs-in-person-tutoring': l => l.data.quick_facts.format.some((f: string) => f === 'online' || f === 'hybrid'),
  'tutoring-cost-thailand-2569': l => l.data.pricing_tier === 'budget',
};
const filterFn = pillarToFilter[pillar.id];
const allListingsForPillar = await getCollection('listings');
const relevantListings = (filterFn
  ? allListingsForPillar.filter(filterFn)
  : [...allListingsForPillar].filter(l => l.data.google_rating)
).sort((a, b) => (b.data.google_rating || 0) - (a.data.google_rating || 0)).slice(0, 6);

const site = Astro.site?.toString() || 'https://tidfun.org/';

// HowTo schema for guide pillars — these have step-by-step preparation timelines
// that match Google's HowTo rich-result criteria
const howToByPillar: Record<string, any> = {
  'how-to-prepare-por1-complete-guide': {
    name: 'วิธีเตรียมสอบเข้า ป.1 โรงเรียนสาธิตและโรงเรียนชั้นนำ',
    totalTime: 'P12M',
    steps: [
      { name: 'อายุ 4 ขวบครึ่ง — ปูพื้นฐาน IQ/EQ', text: 'เริ่มจากการพัฒนาความพร้อม สังเกตการณ์ ฟังคำสั่งซับซ้อน วาดรูป-ระบายสี และเล่นเกมที่ฝึกความคิด ยังไม่ต้องเรียนกวดวิชา แต่ฝึกระเบียบวินัยและสมาธิ' },
      { name: 'อายุ 5 ขวบ — เริ่มเรียนกวดวิชาเตรียมความพร้อม', text: 'เลือกสถาบันที่เน้นเตรียมความพร้อมมากกว่าอัดเนื้อหา เริ่มฝึกการเขียนชื่อตัวเอง ลำดับเลข 1-100 อ่านพยัญชนะ สระไทย และคำง่าย ๆ' },
      { name: 'อายุ 5 ขวบครึ่ง — ฝึกข้อสอบจริง', text: 'หาแนวข้อสอบของโรงเรียนเป้าหมายและฝึกฝนทุกสัปดาห์ เน้นความเข้าใจมากกว่าท่องจำ ให้เด็กลองทำข้อสอบเก่าเพื่อคุ้นเคยกับรูปแบบ' },
      { name: 'ช่วง 2-3 เดือนก่อนสอบ — ทบทวนและประเมินผล', text: 'จัด mock exam ที่บ้านหรือที่สถาบัน ดูจุดอ่อนของลูกและเน้นแก้ไข อย่าฝึกหนักเกินไปเพราะอาจทำให้เครียดและเสียความมั่นใจในวันสอบจริง' },
      { name: 'วันสอบ — เตรียมสภาพและเทคนิคคุมเวลา', text: 'นอนเร็วคืนก่อนสอบ ทานข้าวเช้าให้อิ่ม พกของที่ลูกใช้ฝึกประจำไปด้วย ในห้องสอบให้ลูกหายใจลึกก่อนเริ่ม และข้ามข้อที่ไม่แน่ใจก่อนแล้วค่อยกลับมา' },
    ],
  },
  'how-to-prepare-mor1-complete-guide': {
    name: 'วิธีเตรียมสอบเข้า ม.1 โรงเรียนสาธิตและโรงเรียนรัฐบาลชั้นนำ',
    totalTime: 'P18M',
    steps: [
      { name: 'ป.5 ต้นเทอม — ปูพื้นฐานคณิต-วิทย์ระดับ ม.ต้น', text: 'เริ่มเรียน Pre-mor1 หรือ Pre-คณิตวิทย์ ม.ต้น ปูพื้นฐานเรื่องเศษส่วน ทศนิยม เลขยกกำลัง รากที่สอง และพื้นฐานวิทย์ระดับ ป.6-ม.1' },
      { name: 'ป.5 ปลายเทอม — เริ่มฝึกข้อสอบจริง', text: 'หาข้อสอบเข้า ม.1 ของโรงเรียนเป้าหมายย้อนหลัง 3-5 ปี ลองทำดูเพื่อรู้แนวข้อสอบและความยาก เริ่มจดคะแนนแต่ละครั้งเพื่อดูพัฒนาการ' },
      { name: 'ป.6 ต้นเทอม — เน้นวิชาที่อ่อนสุด', text: 'จากข้อสอบที่ฝึก ดูว่าวิชาไหนคะแนนต่ำสุด ทุ่มเทเวลาเรียนเพิ่มที่วิชานั้น อาจเปลี่ยนสถาบันสำหรับวิชาเฉพาะหรือเพิ่มติวเตอร์ส่วนตัว' },
      { name: 'ป.6 กลางเทอม — Mock exam สม่ำเสมอ', text: 'จัดสอบจำลองทุก 2-3 สัปดาห์ในสภาพแวดล้อมเหมือนสอบจริง คุมเวลาเข้มงวด อย่าให้พ่อแม่ช่วย เพื่อให้ลูกคุ้นกับแรงกดดัน' },
      { name: '2-3 เดือนก่อนสอบ — ทบทวนและสรุปสูตร', text: 'หยุดเรียนเนื้อหาใหม่ เปลี่ยนเป็นทบทวนสรุปสูตรและเทคนิคทำข้อสอบเร็ว ฝึกข้อสอบ 100 ข้อต่อสัปดาห์ เน้น speed accuracy' },
      { name: 'วันสอบและหลังสอบ', text: 'นอนเต็มที่คืนก่อนสอบ ทานอาหารเช้าที่คุ้นเคย ในห้องสอบให้อ่านโจทย์ให้ครบก่อนตอบ เริ่มข้อที่มั่นใจก่อน ข้ามข้อที่ไม่ชัวร์ไปก่อน หลังสอบให้พักผ่อน' },
    ],
  },
  'how-to-prepare-mor4-complete-guide': {
    name: 'วิธีเตรียมสอบเข้า ม.4 เตรียมอุดมศึกษา MWIT และโรงเรียน Gifted',
    totalTime: 'P18M',
    steps: [
      { name: 'ม.2 ต้นเทอม — ปูพื้นคณิต-วิทย์ระดับ ม.ปลาย', text: 'เริ่ม Pre-mor4 ครอบคลุมพีชคณิต ตรีโกณ ฟิสิกส์เบื้องต้น เคมีพื้นฐาน เน้นเข้าใจหลักการมากกว่าท่องสูตร' },
      { name: 'ม.3 ต้นเทอม — เริ่มสอบ entrance ตัวอย่าง', text: 'หาข้อสอบเก่าโรงเรียนเป้าหมายและฝึกทำ จดคะแนนและวิเคราะห์จุดอ่อนรายวิชา ปรับแผนการเรียนตามผลลัพธ์' },
      { name: 'ม.3 กลางเทอม — เพิ่ม Olympiad / Talent search', text: 'สมัครสอบ Olympiad หรือ Talent Search เพื่อฝึกข้อสอบยากและสร้าง profile ที่หลายโรงเรียนรับเข้าโดยตรงโดยไม่ต้องสอบเข้า' },
      { name: '3-6 เดือนก่อนสอบ — Mock exam และทบทวนเชิงลึก', text: 'จัดสอบจำลองเดือนละครั้ง คุมเวลาและบรรยากาศเหมือนจริง ทบทวนเนื้อหาที่ออกบ่อยในข้อสอบหลายปีย้อนหลัง' },
      { name: 'วันสอบ — เทคนิคจัดการเวลาและคำตอบ', text: 'ในห้องสอบจัดสรรเวลาให้แต่ละข้อตามคะแนน ข้ามข้อที่ไม่แน่ใจไปก่อน ใช้เทคนิคตัดตัวเลือกในข้อปรนัย ตรวจคำตอบ 10-15 นาทีก่อนหมดเวลา' },
    ],
  },
  'how-to-prepare-tcas-tgat-tpat': {
    name: 'วิธีเตรียมสอบ TCAS TGAT TPAT A-Level สำหรับการเข้ามหาวิทยาลัย',
    totalTime: 'P12M',
    steps: [
      { name: 'ม.5 ปลายเทอม — เลือก track และวางแผน', text: 'เลือกสายอาชีพและคณะเป้าหมายเพื่อรู้ว่าต้องสอบ TGAT TPAT A-Level วิชาไหน วางแผนระยะ 12-18 เดือนล่วงหน้า' },
      { name: 'ม.6 ต้นเทอม — เริ่มเรียนเข้มข้น', text: 'แบ่งเวลาเรียนตาม weight ของแต่ละวิชาในคณะที่เลือก ใช้สถาบันกวดวิชาที่เชี่ยวชาญแต่ละการสอบ' },
      { name: 'รอบ Portfolio (ปลายปี 5)', text: 'หากใช้รอบ Portfolio ต้องเตรียมผลงานและกิจกรรมตั้งแต่ ม.4-ม.5 รวบรวมเป็น portfolio ที่แสดงความสนใจในสาขาเป้าหมาย' },
      { name: 'รอบโควตา/ Inter (ต้น-กลาง ม.6)', text: 'หากใช้รอบโควตา ตรวจสอบคุณสมบัติของมหาวิทยาลัยและภาควิชา เตรียมเอกสาร transcript และจดหมายแนะนำให้พร้อม' },
      { name: 'รอบ Admission 1+2 (กลาง-ปลาย ม.6) — สอบ TGAT TPAT A-Level', text: 'มุ่งฝึกข้อสอบจำลองจริง คุมเวลาเข้มงวด พักผ่อนสม่ำเสมอ ห้ามอดนอนก่อนสอบใหญ่' },
      { name: 'หลังประกาศผล — เลือกและยืนยันสิทธิ์', text: 'อ่านระเบียบการแต่ละคณะให้ละเอียดก่อนเลือก ตัดสินใจจากความเหมาะสมระยะยาว ไม่ใช่แค่ชื่อคณะหรือมหาวิทยาลัย' },
    ],
  },
};
const howToData = howToByPillar[pillar.id];
const howToSchema = howToData ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${site}pillars/${pillar.id}/#howto`,
  name: howToData.name,
  description: d.description,
  totalTime: howToData.totalTime,
  inLanguage: 'th',
  publisher: { '@id': `${site}#org` },
  step: howToData.steps.map((s: any, i: number) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: s.name,
    text: s.text,
  })),
} : null;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${site}pillars/${pillar.id}/#article`,
  headline: d.title.slice(0, 110),
  description: d.description,
  inLanguage: 'th',
  articleSection: 'การเตรียมสอบและกวดวิชา',
  datePublished: d.publishDate.toISOString(),
  ...(d.updatedDate ? { dateModified: d.updatedDate.toISOString() } : {}),
  author: { '@id': `${site}#editorial-team` },
  publisher: { '@id': `${site}#org` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${site}pillars/${pillar.id}/` },
  isPartOf: { '@id': `${site}#org` },
};
---

<BaseLayout
  title={d.title}
  description={d.description}
  type="article"
  publishDate={d.publishDate}
  updatedDate={d.updatedDate}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}

  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[{ label: d.title.slice(0, 80) }]} />

    <article>
      <header class="mb-8">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3 leading-tight">{d.title}</h1>
        <p class="text-gray-600 leading-relaxed mb-3">{d.description}</p>
        <p class="text-xs text-gray-500">
          เผยแพร่ {d.publishDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' })}
          {d.updatedDate && ` · อัปเดต ${d.updatedDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' })}`}
          · {d.author}
        </p>
      </header>

      <div class="prose max-w-none">
        <Content />
      </div>
    </article>

    {relevantListings.length > 0 && (
      <section class="my-12 bg-gradient-to-br from-indigo-50 to-purple-50 border border-indigo-100 rounded-2xl p-6 md:p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">สถาบันที่เกี่ยวข้องกับบทความนี้</h2>
        <p class="text-gray-600 mb-6 text-sm">สถาบันที่ตรงกับเนื้อหาในบทความ — เริ่มเปรียบเทียบหรือเข้าดูรายละเอียดได้เลย</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {relevantListings.map(r => (
            <a href={`/listing/${r.id}/`} class="block bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md hover:border-indigo-300 transition-all group">
              <h3 class="font-bold text-gray-900 group-hover:text-indigo-600 transition-colors line-clamp-1">{r.data.name_th}</h3>
              <p class="text-xs text-gray-500 mt-1">{r.data.district ? `${r.data.district} · ` : ''}{r.data.city}</p>
              {r.data.google_rating && (
                <p class="text-xs text-amber-600 mt-1">★ {r.data.google_rating.toFixed(1)} ({r.data.google_review_count || 0})</p>
              )}
              <p class="text-xs text-gray-600 mt-2 line-clamp-2">{r.data.description_th.slice(0, 100)}...</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <NewsletterSignup variant="inline" />
  </div>
</BaseLayout>
