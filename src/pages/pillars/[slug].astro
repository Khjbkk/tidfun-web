---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pillars = await getCollection('pillars');
  return pillars.map((p) => ({
    params: { slug: p.id },
    props: { pillar: p },
  }));
}

const { pillar } = Astro.props;
const { Content } = await render(pillar);
const d = pillar.data;

// Pillar → relevant listings widget (commercial-intent funnel from informational content)
const pillarToFilter: Record<string, (l: any) => boolean> = {
  'how-to-prepare-por1-complete-guide': l => l.data.categories.includes('por1'),
  'how-to-prepare-mor1-complete-guide': l => l.data.categories.includes('mor1'),
  'how-to-prepare-mor4-complete-guide': l => l.data.categories.includes('mor4'),
  'how-to-prepare-tcas-tgat-tpat': l => l.data.categories.includes('uni'),
  'english-program-ep-bilingual-thailand': l => l.data.subjects.includes('english'),
  'online-vs-in-person-tutoring': l => l.data.quick_facts.format.some((f: string) => f === 'online' || f === 'hybrid'),
  'tutoring-cost-thailand-2569': l => l.data.pricing_tier === 'budget',
  'tutor-cost-bangkok-2569': l => l.data.city === 'bangkok',
  'tcas-2570-timeline': l => l.data.categories.includes('uni'),
};
const filterFn = pillarToFilter[pillar.id];
const allListingsForPillar = await getCollection('listings');
const relevantListings = (filterFn
  ? allListingsForPillar.filter(filterFn)
  : [...allListingsForPillar].filter(l => l.data.google_rating)
).sort((a, b) => (b.data.google_rating || 0) - (a.data.google_rating || 0)).slice(0, 6);

const site = Astro.site?.toString() || 'https://tidfun.org/';

// HowTo schema for guide pillars — these have step-by-step preparation timelines
// that match Google's HowTo rich-result criteria
const howToByPillar: Record<string, any> = {
  'how-to-prepare-por1-complete-guide': {
    name: 'วิธีเตรียมสอบเข้า ป.1 โรงเรียนสาธิตและโรงเรียนชั้นนำ',
    totalTime: 'P12M',
    steps: [
      { name: 'อายุ 4 ขวบครึ่ง — ปูพื้นฐาน IQ/EQ', text: 'เริ่มจากการพัฒนาความพร้อม สังเกตการณ์ ฟังคำสั่งซับซ้อน วาดรูป-ระบายสี และเล่นเกมที่ฝึกความคิด ยังไม่ต้องเรียนกวดวิชา แต่ฝึกระเบียบวินัยและสมาธิ' },
      { name: 'อายุ 5 ขวบ — เริ่มเรียนกวดวิชาเตรียมความพร้อม', text: 'เลือกสถาบันที่เน้นเตรียมความพร้อมมากกว่าอัดเนื้อหา เริ่มฝึกการเขียนชื่อตัวเอง ลำดับเลข 1-100 อ่านพยัญชนะ สระไทย และคำง่าย ๆ' },
      { name: 'อายุ 5 ขวบครึ่ง — ฝึกข้อสอบจริง', text: 'หาแนวข้อสอบของโรงเรียนเป้าหมายและฝึกฝนทุกสัปดาห์ เน้นความเข้าใจมากกว่าท่องจำ ให้เด็กลองทำข้อสอบเก่าเพื่อคุ้นเคยกับรูปแบบ' },
      { name: 'ช่วง 2-3 เดือนก่อนสอบ — ทบทวนและประเมินผล', text: 'จัด mock exam ที่บ้านหรือที่สถาบัน ดูจุดอ่อนของลูกและเน้นแก้ไข อย่าฝึกหนักเกินไปเพราะอาจทำให้เครียดและเสียความมั่นใจในวันสอบจริง' },
      { name: 'วันสอบ — เตรียมสภาพและเทคนิคคุมเวลา', text: 'นอนเร็วคืนก่อนสอบ ทานข้าวเช้าให้อิ่ม พกของที่ลูกใช้ฝึกประจำไปด้วย ในห้องสอบให้ลูกหายใจลึกก่อนเริ่ม และข้ามข้อที่ไม่แน่ใจก่อนแล้วค่อยกลับมา' },
    ],
  },
  'how-to-prepare-mor1-complete-guide': {
    name: 'วิธีเตรียมสอบเข้า ม.1 โรงเรียนสาธิตและโรงเรียนรัฐบาลชั้นนำ',
    totalTime: 'P18M',
    steps: [
      { name: 'ป.5 ต้นเทอม — ปูพื้นฐานคณิต-วิทย์ระดับ ม.ต้น', text: 'เริ่มเรียน Pre-mor1 หรือ Pre-คณิตวิทย์ ม.ต้น ปูพื้นฐานเรื่องเศษส่วน ทศนิยม เลขยกกำลัง รากที่สอง และพื้นฐานวิทย์ระดับ ป.6-ม.1' },
      { name: 'ป.5 ปลายเทอม — เริ่มฝึกข้อสอบจริง', text: 'หาข้อสอบเข้า ม.1 ของโรงเรียนเป้าหมายย้อนหลัง 3-5 ปี ลองทำดูเพื่อรู้แนวข้อสอบและความยาก เริ่มจดคะแนนแต่ละครั้งเพื่อดูพัฒนาการ' },
      { name: 'ป.6 ต้นเทอม — เน้นวิชาที่อ่อนสุด', text: 'จากข้อสอบที่ฝึก ดูว่าวิชาไหนคะแนนต่ำสุด ทุ่มเทเวลาเรียนเพิ่มที่วิชานั้น อาจเปลี่ยนสถาบันสำหรับวิชาเฉพาะหรือเพิ่มติวเตอร์ส่วนตัว' },
      { name: 'ป.6 กลางเทอม — Mock exam สม่ำเสมอ', text: 'จัดสอบจำลองทุก 2-3 สัปดาห์ในสภาพแวดล้อมเหมือนสอบจริง คุมเวลาเข้มงวด อย่าให้พ่อแม่ช่วย เพื่อให้ลูกคุ้นกับแรงกดดัน' },
      { name: '2-3 เดือนก่อนสอบ — ทบทวนและสรุปสูตร', text: 'หยุดเรียนเนื้อหาใหม่ เปลี่ยนเป็นทบทวนสรุปสูตรและเทคนิคทำข้อสอบเร็ว ฝึกข้อสอบ 100 ข้อต่อสัปดาห์ เน้น speed accuracy' },
      { name: 'วันสอบและหลังสอบ', text: 'นอนเต็มที่คืนก่อนสอบ ทานอาหารเช้าที่คุ้นเคย ในห้องสอบให้อ่านโจทย์ให้ครบก่อนตอบ เริ่มข้อที่มั่นใจก่อน ข้ามข้อที่ไม่ชัวร์ไปก่อน หลังสอบให้พักผ่อน' },
    ],
  },
  'how-to-prepare-mor4-complete-guide': {
    name: 'วิธีเตรียมสอบเข้า ม.4 เตรียมอุดมศึกษา MWIT และโรงเรียน Gifted',
    totalTime: 'P18M',
    steps: [
      { name: 'ม.2 ต้นเทอม — ปูพื้นคณิต-วิทย์ระดับ ม.ปลาย', text: 'เริ่ม Pre-mor4 ครอบคลุมพีชคณิต ตรีโกณ ฟิสิกส์เบื้องต้น เคมีพื้นฐาน เน้นเข้าใจหลักการมากกว่าท่องสูตร' },
      { name: 'ม.3 ต้นเทอม — เริ่มสอบ entrance ตัวอย่าง', text: 'หาข้อสอบเก่าโรงเรียนเป้าหมายและฝึกทำ จดคะแนนและวิเคราะห์จุดอ่อนรายวิชา ปรับแผนการเรียนตามผลลัพธ์' },
      { name: 'ม.3 กลางเทอม — เพิ่ม Olympiad / Talent search', text: 'สมัครสอบ Olympiad หรือ Talent Search เพื่อฝึกข้อสอบยากและสร้าง profile ที่หลายโรงเรียนรับเข้าโดยตรงโดยไม่ต้องสอบเข้า' },
      { name: '3-6 เดือนก่อนสอบ — Mock exam และทบทวนเชิงลึก', text: 'จัดสอบจำลองเดือนละครั้ง คุมเวลาและบรรยากาศเหมือนจริง ทบทวนเนื้อหาที่ออกบ่อยในข้อสอบหลายปีย้อนหลัง' },
      { name: 'วันสอบ — เทคนิคจัดการเวลาและคำตอบ', text: 'ในห้องสอบจัดสรรเวลาให้แต่ละข้อตามคะแนน ข้ามข้อที่ไม่แน่ใจไปก่อน ใช้เทคนิคตัดตัวเลือกในข้อปรนัย ตรวจคำตอบ 10-15 นาทีก่อนหมดเวลา' },
    ],
  },
  'how-to-prepare-tcas-tgat-tpat': {
    name: 'วิธีเตรียมสอบ TCAS TGAT TPAT A-Level สำหรับการเข้ามหาวิทยาลัย',
    totalTime: 'P12M',
    steps: [
      { name: 'ม.5 ปลายเทอม — เลือก track และวางแผน', text: 'เลือกสายอาชีพและคณะเป้าหมายเพื่อรู้ว่าต้องสอบ TGAT TPAT A-Level วิชาไหน วางแผนระยะ 12-18 เดือนล่วงหน้า' },
      { name: 'ม.6 ต้นเทอม — เริ่มเรียนเข้มข้น', text: 'แบ่งเวลาเรียนตาม weight ของแต่ละวิชาในคณะที่เลือก ใช้สถาบันกวดวิชาที่เชี่ยวชาญแต่ละการสอบ' },
      { name: 'รอบ Portfolio (ปลายปี 5)', text: 'หากใช้รอบ Portfolio ต้องเตรียมผลงานและกิจกรรมตั้งแต่ ม.4-ม.5 รวบรวมเป็น portfolio ที่แสดงความสนใจในสาขาเป้าหมาย' },
      { name: 'รอบโควตา/ Inter (ต้น-กลาง ม.6)', text: 'หากใช้รอบโควตา ตรวจสอบคุณสมบัติของมหาวิทยาลัยและภาควิชา เตรียมเอกสาร transcript และจดหมายแนะนำให้พร้อม' },
      { name: 'รอบ Admission 1+2 (กลาง-ปลาย ม.6) — สอบ TGAT TPAT A-Level', text: 'มุ่งฝึกข้อสอบจำลองจริง คุมเวลาเข้มงวด พักผ่อนสม่ำเสมอ ห้ามอดนอนก่อนสอบใหญ่' },
      { name: 'หลังประกาศผล — เลือกและยืนยันสิทธิ์', text: 'อ่านระเบียบการแต่ละคณะให้ละเอียดก่อนเลือก ตัดสินใจจากความเหมาะสมระยะยาว ไม่ใช่แค่ชื่อคณะหรือมหาวิทยาลัย' },
    ],
  },
  'tcas-2570-timeline': {
    name: 'วิธีสมัคร TCAS 2570 ทั้ง 4 รอบ สำหรับ dek70',
    totalTime: 'P8M',
    steps: [
      { name: 'ก.ค.–ส.ค. 2569 — subscribe ปฏิทิน ทปอ.', text: 'สมัครรับแจ้งเตือนที่ mytcas.com เพื่อรับกำหนดการอย่างเป็นทางการทันทีที่ ทปอ. ประกาศ อย่ารอข่าวจากสื่อรอง เพราะกำหนดการอาจปรับได้ 1-2 สัปดาห์' },
      { name: 'ก.ย.–ต.ค. 2569 — ตัดสินใจคณะเป้าหมาย', text: 'เลือกคณะเป้าหมาย 3 อันดับ + คณะสำรอง 3 อันดับ ตรวจ GPAX ที่คณะต้องการ ประเมินคะแนน TGAT/TPAT ที่ต้องได้จากข้อมูลย้อนหลัง 3 ปี' },
      { name: 'พ.ย. 2569 – ก.พ. 2570 — สมัครรอบ 1 Portfolio', text: 'ส่ง portfolio 10 หน้า พร้อมจดหมายแนะนำและ GPAX 4 เทอมแรก บางคณะต้องมีคะแนน TOEFL/IELTS ส่งล่วงหน้า 7 วันก่อน deadline' },
      { name: 'ธ.ค. 2569 — สอบ TGAT/TPAT รอบแรก', text: 'สทศ. จัดสอบ TGAT/TPAT ตามปฏิทิน คะแนนใช้ได้ 2 ปี ควรสอบครั้งนี้แม้จะยังไม่พร้อม 100% เพราะสามารถสอบซ้ำในรอบ 2 (มี.ค. 2570) และเลือกคะแนนสูงสุด' },
      { name: 'ก.พ.–พ.ค. 2570 — สมัครรอบ 2 Quota (โควตา)', text: 'ตรวจคุณสมบัติโควตา (ภูมิภาค / MOU / กสพท.) เตรียมเอกสารเพิ่มเติมตามที่โควตากำหนด ใช้คะแนน TGAT + วิชาเฉพาะที่คณะระบุ' },
      { name: 'มี.ค. 2570 — สอบ A-Level + TGAT/TPAT รอบ 2', text: 'สอบ A-Level 7 วิชาที่คณะต้องการ พร้อมสอบ TGAT/TPAT ซ้ำเพื่อปรับคะแนนถ้ารอบแรกได้ต่ำ ระบบเลือกคะแนนสูงสุดโดยอัตโนมัติ' },
      { name: 'พ.ค. 2570 — สมัครและยืนยันสิทธิ์รอบ 3 Admission', text: 'เลือกคณะสูงสุด 10 อันดับเรียงตามความต้องการ ระบบ ทปอ. จับคู่อัตโนมัติ ต้องยืนยันสิทธิ์ภายใน 3 วันหลังประกาศผล ไม่ยืนยันถือว่าสละสิทธิ์' },
      { name: 'พ.ค.–มิ.ย. 2570 — รอบ 4 Direct Admission (ทางเลือกสุดท้าย)', text: 'ถ้ายังไม่ได้ที่นั่ง สมัครตรงกับมหาวิทยาลัยแต่ละแห่ง ที่นั่งน้อยกว่ารอบ 3 มาก (5% vs 40%) คณะยอดฮิตส่วนใหญ่ปิดรับตั้งแต่รอบ 3' },
    ],
  },
};
const howToData = howToByPillar[pillar.id];
const howToSchema = howToData ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${site}pillars/${pillar.id}/#howto`,
  name: howToData.name,
  description: d.description,
  totalTime: howToData.totalTime,
  inLanguage: 'th',
  publisher: { '@id': `${site}#org` },
  step: howToData.steps.map((s: any, i: number) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: s.name,
    text: s.text,
  })),
} : null;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${site}pillars/${pillar.id}/#article`,
  headline: d.title.slice(0, 110),
  description: d.description,
  inLanguage: 'th',
  articleSection: 'การเตรียมสอบและกวดวิชา',
  datePublished: d.publishDate.toISOString(),
  ...(d.updatedDate ? { dateModified: d.updatedDate.toISOString() } : {}),
  author: { '@id': `${site}#editorial-team` },
  publisher: { '@id': `${site}#org` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${site}pillars/${pillar.id}/` },
  isPartOf: { '@id': `${site}#org` },
};

// FAQPage schema per pillar (optional). AI platforms — ChatGPT / Perplexity /
// Google AI Overviews — cite FAQ items directly when marked with FAQPage.
const faqByPillar: Record<string, Array<{ q: string; a: string }>> = {
  'tutor-cost-bangkok-2569': [
    { q: 'ราคาติวเตอร์กรุงเทพเฉลี่ยเดือนละกี่บาท?', a: 'จากข้อมูล 254 สถาบันในกรุงเทพในฐาน tidfun.org ค่ามัธยฐานอยู่ที่ ฿5,300/เดือน โดย 50% ของสถาบันคิดราคาระหว่าง ฿4,950-฿5,650 ครอบคลุมคอร์ส 5-8 วิชา แบบสถาบันกวดวิชากลุ่มเล็ก-กลาง ถ้าเรียนตัวต่อตัวหรือย่านใจกลางเมืองต้องบวก 15-45%' },
    { q: 'ติวเตอร์ตัวต่อตัวกับสถาบันกวดวิชากลุ่ม คุ้มอันไหนกว่า?', a: 'ขึ้นกับลักษณะของเด็ก ติวเตอร์ตัวต่อตัวมัธยฐาน ฿7,000/เดือน เหมาะเด็กที่มีจุดอ่อนเฉพาะวิชา ต้องการ pace เร็วหรือช้ากว่าปกติ สถาบันกลุ่มมัธยฐาน ฿5,300/เดือน เหมาะเด็กที่ทำงานดีในสภาพแวดล้อมกลุ่ม มี peer pressure และมี mock exam ครบวงจร' },
    { q: 'ทำไมค่าเรียน IELTS/SAT/TOEFL แพงกว่าวิชาภาษาอังกฤษทั่วไป?', a: 'IELTS มัธยฐาน ฿6,950/เดือน สูงกว่าภาษาอังกฤษทั่วไป 30% เพราะครูต้องมีประสบการณ์สอนสอบเฉพาะทางและถือใบเซอร์ระดับสูง ข้อสอบใช้เทคนิคเฉพาะที่ต้องฝึกซ้ำ และครอบครัวที่เตรียมไปต่างประเทศยอมจ่ายราคาสูงกว่า' },
    { q: 'ผู้ปกครองควรมัดจำล่วงหน้ากี่เดือน?', a: 'ตามคำแนะนำของสำนักงานคณะกรรมการคุ้มครองผู้บริโภค (สคบ.) ไม่ควรมัดจำเกิน 3 เดือน สถาบันน่าเชื่อถือรับจ่ายเป็นเดือน หรือให้ส่วนลด 10-20% เมื่อจ่ายเป็นเทอม 4 เดือน หากถูกบังคับจ่าย 6-12 เดือนล่วงหน้ามีความเสี่ยงสูงขอเงินคืนไม่ได้' },
    { q: 'ค่าเรียนพิเศษหักภาษีเงินได้บุคคลธรรมดาได้ไหม?', a: 'ตามประมวลรัษฎากรของกรมสรรพากร ค่าเรียนพิเศษของบุตรที่เรียนในโรงเรียนกวดวิชาไม่จัดเป็นค่าลดหย่อนภาษี ไม่เหมือนค่าเทอมโรงเรียนในระบบ ยกเว้นกรณีสถาบันจดทะเบียนเป็นโรงเรียนในระบบ ผู้ปกครองควรตรวจสอบสถานะกับกรมสรรพากรก่อน' },
    { q: 'ราคาออนไลน์ถูกกว่า in-person จริงไหม?', a: 'จริง สถาบันแบบออนไลน์ล้วนมัธยฐาน ฿3,550/เดือน เทียบกับสถาบันมีหน้าร้าน ฿5,300 (ต่างกัน 33%) แต่ต้องคำนึงถึงค่าอุปกรณ์ ความเสี่ยงเด็กเสียสมาธิ และเด็กเล็กที่ต้องการดูแลใกล้ชิด งานวิจัย OECD ระบุประสิทธิผลออนไลน์ต่ำสำหรับเด็กต่ำกว่า ม.1' },
    { q: 'ครูสอนไม่ดี ผู้ปกครองขอเงินคืนได้ไหม?', a: 'ได้ ตาม พ.ร.บ.คุ้มครองผู้บริโภค พ.ศ. 2522 หากสถาบันไม่ปฏิบัติตามคำโฆษณาหรือคุณภาพต่ำกว่าที่ระบุในสัญญา ผู้ปกครองมีสิทธิขอเงินคืนตามสัดส่วนที่ยังไม่ได้ใช้บริการ หลักฐาน: สัญญา ใบเสร็จ บันทึกการเข้าเรียน หากปฏิเสธร้องเรียนที่ สคบ. สายด่วน 1166' },
    { q: 'ครู 20,000 บาท/คอร์ส กับครู 500 บาท/ชม. คุ้มอันไหน?', a: 'คำนวณเป็นราคาต่อชั่วโมงเสียก่อน คอร์ส 20,000 มักครอบคลุม 30-40 ชั่วโมง = 500-667 บาท/ชม. ใกล้เคียงครูรายชั่วโมง หากครูคอร์สมีวัสดุการเรียน mock exam และการติดตามผลด้วย อาจคุ้มกว่า แต่หากครูรายชั่วโมงมีประสบการณ์เฉพาะทางสูงกว่า อาจคุ้มกว่าในระยะยาว' },
  ],
  'tcas-2570-timeline': [
    { q: 'TCAS 2570 เริ่มสมัครวันไหน?', a: 'รอบ 1 Portfolio คาดการณ์เปิดสมัครประมาณกลาง พ.ย. 2569 (ปิด ก.พ. 2570) ตามรูปแบบปฏิทินย้อนหลัง 3 ปี ทปอ. จะประกาศกำหนดการอย่างเป็นทางการที่ mytcas.com ในช่วง ก.ค.-ส.ค. 2569 dek70 ควร subscribe แจ้งเตือนที่เว็บของ ทปอ.' },
    { q: 'ยืนยันสิทธิ์รอบ 1 แล้ว สมัครรอบ 2 ได้ไหม?', a: 'ไม่ได้ การยืนยันสิทธิ์รอบใดรอบหนึ่งแล้วจะถูกระบบล็อค สมัครรอบต่อไปไม่ได้ทันที ต้องกดสละสิทธิ์ที่ mytcas.com ก่อน จึงจะสามารถสมัครรอบต่อไปได้ แต่การสละสิทธิ์มีความเสี่ยงเพราะไม่การันตีได้ที่นั่งในรอบต่อไป' },
    { q: 'คะแนน TGAT / TPAT / A-Level ใช้ได้กี่ปี?', a: 'ตามระเบียบของ สทศ. คะแนน TGAT/TPAT ใช้ได้ 2 ปีนับจากวันสอบ A-Level ใช้ได้ 2 ปีเช่นกัน dek69 ที่สอบ TGAT ในเดือน ธ.ค. 2568 สามารถใช้สมัคร TCAS 2570 ได้ในบางรอบ แต่ต้องเช็คระเบียบการของคณะเพราะบางคณะยอมรับเฉพาะคะแนนปีล่าสุด' },
    { q: 'ค่าสมัครแต่ละรอบเท่าไหร่?', a: 'ตามอัตราของ TCAS 2569 ค่าสมัครรอบ 1-4 อยู่ที่ 100-350 บาทต่อคณะ รอบ 3 Admission มีค่าสมัครสูงสุดเพราะเลือกได้สูงสุด 10 อันดับ ประมาณ 800-1,200 บาทรวม ทปอ. จะประกาศอัตรา TCAS 2570 พร้อมกำหนดการอย่างเป็นทางการที่ mytcas.com' },
    { q: 'รอบ 4 คืออะไร ต่างจากรอบ 3 ยังไง?', a: 'รอบ 3 Admission ใช้ระบบ sort กลางของ ทปอ. เลือกได้สูงสุด 10 อันดับ ระบบจับคู่อัตโนมัติ รอบ 4 Direct Admission มหาลัยรับตรงเอง นักเรียนสมัครกับแต่ละมหาวิทยาลัยแยกกัน คุณสมบัติกำหนดโดยมหาวิทยาลัย ที่นั่งรอบ 4 น้อยกว่ารอบ 3 มาก (5% vs 40%)' },
    { q: 'GPAX ต้องใช้เท่าไหร่?', a: 'ไม่มีเกณฑ์กลาง แต่ละคณะกำหนดเอง คณะยอดฮิต (แพทย์ ทันตะ วิศวะจุฬา) มักต้องการ GPAX ≥ 3.50 คณะทั่วไป 2.75-3.00 GPAX ที่ใช้คือ 4-6 ภาคเรียนของ ม.4-ม.6 ตามที่คณะกำหนด dek70 ควรเช็คระเบียบการแต่ละคณะที่ mytcas.com' },
    { q: 'dek69 vs dek70 ต่างกันยังไง?', a: 'dek69 คือนักเรียนที่จบ ม.6 ในเดือน ก.พ. 2569 และสมัคร TCAS 2569 (จบไปแล้ว) dek70 คือนักเรียนที่จบ ม.6 ในเดือน ก.พ. 2570 และสมัคร TCAS 2570 ปฏิทินและเกณฑ์คะแนนอาจต่างกันเล็กน้อยตามที่ ทปอ. ปรับ dek70 ต้องอ่านระเบียบการของปี 2570 โดยเฉพาะ' },
    { q: 'ถ้าซิ่วสมัคร TCAS 2570 รอบไหนได้บ้าง?', a: 'นักเรียนซิ่ว (จบ ม.6 มาแล้ว) สามารถสมัคร TCAS 2570 ได้ทุกรอบ แต่ต้องสละสิทธิ์จากมหาวิทยาลัยเดิมก่อน (ถ้ายังศึกษาอยู่) และใช้คะแนน TGAT/TPAT/A-Level ในกรอบเวลาที่ระเบียบการอนุญาต บางคณะจำกัดจำนวนซิ่วรับได้ต่อปี' },
  ],
};
const faqData = faqByPillar[pillar.id];
const faqSchema = faqData ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${site}pillars/${pillar.id}/#faq`,
  mainEntity: faqData.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

// AggregateOffer schema per pillar — for posts that cite a real price range
// backed by our listing dataset. Google surfaces this as a price rich result.
const aggregateOfferByPillar: Record<string, { low: number; high: number; count: number; source: string }> = {
  'tutor-cost-bangkok-2569': {
    low: 1900, high: 16000, count: 254,
    source: 'tidfun.org internal listings dataset (Bangkok, monthly-rate subset)',
  },
};
const aggData = aggregateOfferByPillar[pillar.id];
const aggregateOfferSchema = aggData ? {
  '@context': 'https://schema.org',
  '@type': 'AggregateOffer',
  '@id': `${site}pillars/${pillar.id}/#offers`,
  priceCurrency: 'THB',
  lowPrice: aggData.low,
  highPrice: aggData.high,
  offerCount: aggData.count,
  availability: 'https://schema.org/InStock',
  category: 'EducationalService',
  description: aggData.source,
} : null;
---

<BaseLayout
  title={d.title}
  description={d.description}
  type="article"
  publishDate={d.publishDate}
  updatedDate={d.updatedDate}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  {aggregateOfferSchema && <script type="application/ld+json" set:html={JSON.stringify(aggregateOfferSchema)} />}

  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumb items={[{ label: d.title.slice(0, 80) }]} />

    <article>
      <header class="mb-8">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3 leading-tight">{d.title}</h1>
        <p class="text-gray-600 leading-relaxed mb-3">{d.description}</p>
        <p class="text-xs text-gray-500">
          เผยแพร่ {d.publishDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' })}
          {d.updatedDate && ` · อัปเดต ${d.updatedDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' })}`}
          · {d.author}
        </p>
      </header>

      <div class="prose max-w-none">
        <Content />
      </div>
    </article>

    {relevantListings.length > 0 && (
      <section class="my-12 bg-gradient-to-br from-indigo-50 to-purple-50 border border-indigo-100 rounded-2xl p-6 md:p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">สถาบันที่เกี่ยวข้องกับบทความนี้</h2>
        <p class="text-gray-600 mb-6 text-sm">สถาบันที่ตรงกับเนื้อหาในบทความ — เริ่มเปรียบเทียบหรือเข้าดูรายละเอียดได้เลย</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {relevantListings.map(r => (
            <a href={`/listing/${r.id}/`} class="block bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md hover:border-indigo-300 transition-all group">
              <h3 class="font-bold text-gray-900 group-hover:text-indigo-600 transition-colors line-clamp-1">{r.data.name_th}</h3>
              <p class="text-xs text-gray-500 mt-1">{r.data.district ? `${r.data.district} · ` : ''}{r.data.city}</p>
              {r.data.google_rating && (
                <p class="text-xs text-amber-600 mt-1">★ {r.data.google_rating.toFixed(1)} ({r.data.google_review_count || 0})</p>
              )}
              <p class="text-xs text-gray-600 mt-2 line-clamp-2">{r.data.description_th.slice(0, 100)}...</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <NewsletterSignup variant="inline" />
  </div>
</BaseLayout>
