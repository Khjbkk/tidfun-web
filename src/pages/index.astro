---
import BaseLayout from '../layouts/BaseLayout.astro';
import ListingCard from '../components/ListingCard.astro';
import FAQSection from '../components/FAQSection.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import PricingHeatmap from '../components/PricingHeatmap.astro';
import { getCollection } from 'astro:content';

const listings = await getCollection('listings');
const categories = await getCollection('categories');
const schools = await getCollection('schools');
const cities = await getCollection('cities');
const pillars = await getCollection('pillars');

const featured = listings.filter(l => l.data.featured).slice(0, 6);
const recent = listings.slice(0, 8);

const sortedCategories = categories.sort((a, b) => a.data.sort - b.data.sort);
const topSchools = schools.sort((a, b) => a.data.sort - b.data.sort);
const topCities = cities.filter(c => c.data.id !== 'online').sort((a, b) => a.data.sort - b.data.sort).slice(0, 6);

const site = Astro.site?.toString() || 'https://tidfun.org/';
// Homepage WebPage schema — sets the page-level entity so other schemas can @id reference it
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': site,
  url: site,
  name: 'ติดฝัน — Directory ติวเตอร์-สถาบันกวดวิชา',
  description: 'รวมสถาบันกวดวิชาและติวเตอร์ทั่วประเทศไทย เตรียมสอบเข้า ป.1 ม.1 ม.4 มหาวิทยาลัย',
  inLanguage: 'th',
  isPartOf: { '@id': `${site}#org` },
  about: { '@id': `${site}#org` },
  primaryImageOfPage: { '@type': 'ImageObject', url: `${site}logo.png` },
  speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.home-hero-claim'] },
};

// ItemList of featured listings — improves SERP appearance for brand queries
const featuredListSchema = featured.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'สถาบันแนะนำบนติดฝัน',
  numberOfItems: featured.length,
  itemListElement: featured.map((l, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${site}listing/${l.id}/`,
    name: l.data.name_th,
  })),
} : null;

const homeFaq = [
  {
    question: 'ติดฝัน คือเว็บไซต์อะไร?',
    answer: 'ติดฝัน (TidFun) คือ directory แห่งสถาบันกวดวิชาและติวเตอร์ทั่วประเทศไทยที่เตรียมเด็กสอบเข้าโรงเรียนสาธิต โรงเรียนชั้นนำ และมหาวิทยาลัย ผู้ปกครองสามารถค้นหาเปรียบเทียบและติดต่อสถาบันที่เหมาะกับลูกได้ในที่เดียว ดำเนินงานโดยบริษัท ซิโอร่า จำกัด',
  },
  {
    question: 'การใช้งานติดฝัน เสียค่าใช้จ่ายไหม?',
    answer: 'สำหรับผู้ปกครองและนักเรียน การค้นหาและดูข้อมูลสถาบันทั้งหมดบนติดฝัน ฟรี ไม่มีค่าใช้จ่าย เราไม่เก็บค่าใช้บริการจากผู้ค้นหา การติดต่อสถาบันโดยตรงผ่านช่องทางที่แต่ละสถาบันแสดงไว้ ไม่ผ่านค่ากลางของติดฝัน',
  },
  {
    question: 'จะรู้ได้อย่างไรว่าข้อมูลในติดฝัน เชื่อถือได้?',
    answer: 'ติดฝันรวบรวมข้อมูลจากหลายแหล่ง ทั้งการ scrape Google Maps การติดต่อสถาบันโดยตรง และข้อมูลที่สถาบันส่งให้เราเอง สถาบันที่มีเครื่องหมาย Claimed คือสถาบันที่ยืนยันข้อมูลกับเราโดยตรง ส่วนสถาบันที่ยังไม่ได้เคลม ข้อมูลอาจมาจากแหล่งสาธารณะและขอแนะนำให้ผู้ใช้ตรวจสอบกับสถาบันอีกครั้ง',
  },
  {
    question: 'ฉันเป็นเจ้าของสถาบัน อยากเพิ่มของฉันต้องทำอย่างไร?',
    answer: 'เจ้าของสถาบันกวดวิชาและติวเตอร์อิสระสามารถเพิ่มสถาบันของตนเข้าสู่ติดฝัน ฟรี ผ่านฟอร์มเคลมที่ลิงก์ "เพิ่มสถาบันของคุณ ฟรี" หรือติดต่อทางอีเมล info@tidfun.com เราจะตรวจสอบและเปิดให้แสดงผลบนเว็บไซต์ภายใน 2-3 วันทำการ',
  },
  {
    question: 'อยากแนะนำสถาบันที่ดีให้ติดฝัน เพิ่มได้ไหม?',
    answer: 'ได้ ติดฝันยินดีรับคำแนะนำสถาบันจากผู้ใช้ทุกท่าน ส่งชื่อสถาบัน เว็บไซต์ หรือลิงก์ Facebook มาที่ info@tidfun.com ทีมงานจะตรวจสอบและเพิ่มเข้า directory ถ้าผ่านเกณฑ์คุณภาพของเรา',
  },
];
---

<BaseLayout
  title="ติดฝัน — Directory ติวเตอร์-สถาบันกวดวิชา หาที่ติวที่ใช่ใน 3 นาที"
  description="ติดฝัน รวมสถาบันกวดวิชาและติวเตอร์ทั่วประเทศไทย เตรียมสอบเข้า ป.1 ม.1 ม.4 มหาวิทยาลัย ค้นหาตามโรงเรียน วิชา พื้นที่ ราคา หาที่ติวที่ใช่กับลูกของคุณ"
>
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  {featuredListSchema && <script type="application/ld+json" set:html={JSON.stringify(featuredListSchema)} />}

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-indigo-600 via-purple-600 to-indigo-800 text-white py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute -top-20 -right-20 w-96 h-96 rounded-full bg-purple-400"></div>
      <div class="absolute -bottom-32 -left-16 w-80 h-80 rounded-full bg-indigo-400"></div>
    </div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-purple-200 font-semibold text-sm tracking-widest uppercase mb-4">Directory ติวเตอร์ที่ใหญ่ที่สุดในไทย</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight">
        หาที่ติวที่ใช่<br />
        <span class="text-amber-300">ให้ลูกติดโรงเรียนในฝัน</span>
      </h1>
      <p class="home-hero-claim text-lg md:text-xl text-white/85 max-w-2xl mx-auto mb-8">
        รวมสถาบันกวดวิชาและติวเตอร์ทั่วประเทศ เตรียมสอบเข้า ป.1 ม.1 ม.4 มหาวิทยาลัย ค้นหาตามโรงเรียน วิชา พื้นที่ ราคา
      </p>

      <form action="/search" method="get" class="max-w-2xl mx-auto bg-white rounded-2xl p-2 flex flex-col sm:flex-row gap-2 shadow-2xl">
        <input
          type="search"
          name="q"
          placeholder="เช่น ติวเตอร์คณิต ม.1 กรุงเทพ หรือ สาธิตจุฬา ป.1"
          class="flex-1 px-4 py-3 text-gray-900 rounded-xl focus:outline-none"
        />
        <button type="submit" class="px-8 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-colors">
          ค้นหา
        </button>
      </form>

      <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm">
        <a href="/tool/find-my-tutor/" class="inline-flex items-center gap-2 bg-amber-400 hover:bg-amber-500 text-amber-900 font-semibold px-5 py-2.5 rounded-full transition-colors">
          🎯 หาติวเตอร์ที่ใช่ใน 3 นาที (ฟรี)
        </a>
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <!-- Categories -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">ค้นหาตามระดับชั้น</h2>
      <p class="text-gray-600 mb-6">เลือกระดับที่ลูกจะสอบเข้าเพื่อดูสถาบันที่เชี่ยวชาญเฉพาะระดับนั้น</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {sortedCategories.map((c) => (
          <a href={`/category/${c.data.id}/`} class="block bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md hover:border-indigo-300 transition-all group">
            <div class="text-4xl mb-3">{c.data.icon}</div>
            <h3 class="font-bold text-gray-900 group-hover:text-indigo-600 transition-colors">{c.data.name_th}</h3>
            <p class="text-xs text-gray-500 mt-1">{c.data.short_th}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Top Schools (Flagship for-school pages) -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">เตรียมสอบเข้าโรงเรียนเป้าหมาย</h2>
      <p class="text-gray-600 mb-6">เลือกโรงเรียนที่ลูกอยากเข้าเพื่อดูสถาบันที่เชี่ยวชาญแนวข้อสอบของโรงเรียนนั้น</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {topSchools.map((s) => (
          <a href={`/for-school/${s.data.id}/`} class="block bg-white border border-gray-200 rounded-xl p-5 hover:shadow-md hover:border-indigo-300 transition-all group">
            <div class="flex items-start gap-3">
              <div class="text-2xl">🏫</div>
              <div class="flex-1">
                <h3 class="font-bold text-gray-900 group-hover:text-indigo-600 transition-colors">{s.data.name_th}</h3>
                <p class="text-xs text-gray-500 mt-0.5">{s.data.full_name_th}</p>
                <p class="text-sm text-gray-600 mt-2 line-clamp-2">{s.data.description_th}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Featured listings -->
    {featured.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">⭐ สถาบันแนะนำ</h2>
        <p class="text-gray-600 mb-6">สถาบันที่ผ่านการตรวจสอบและแนะนำโดยทีมงานติดฝัน</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {featured.map((l) => (
            <ListingCard
              slug={l.id}
              name_th={l.data.name_th}
              city={l.data.city}
              district={l.data.district}
              categories={l.data.categories}
              subjects={l.data.subjects}
              pricing_tier={l.data.pricing_tier}
              format={l.data.quick_facts.format}
              google_rating={l.data.google_rating}
              google_review_count={l.data.google_review_count}
              description_excerpt={l.data.description_th.slice(0, 120) + '...'}
              featured={l.data.featured}
              claimed={l.data.claimed}
            />
          ))}
        </div>
      </section>
    )}

    <!-- All recent listings -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">เพิ่มเข้า directory ล่าสุด</h2>
      <p class="text-gray-600 mb-6">สถาบันใหม่ที่เพิ่งเพิ่มเข้าฐานข้อมูล อัปเดตเป็นประจำทุกสัปดาห์</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {recent.map((l) => (
          <ListingCard
            slug={l.id}
            name_th={l.data.name_th}
            city={l.data.city}
            district={l.data.district}
            categories={l.data.categories}
            subjects={l.data.subjects}
            pricing_tier={l.data.pricing_tier}
            format={l.data.quick_facts.format}
            google_rating={l.data.google_rating}
            google_review_count={l.data.google_review_count}
            description_excerpt={l.data.description_th.slice(0, 120) + '...'}
            featured={l.data.featured}
            claimed={l.data.claimed}
          />
        ))}
      </div>
    </section>

    <!-- Cities -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">ค้นหาตามพื้นที่</h2>
      <p class="text-gray-600 mb-6">ดูสถาบันในจังหวัดที่คุณอยู่</p>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
        {topCities.map((c) => (
          <a href={`/city/${c.data.id}/`} class="block bg-white border border-gray-200 rounded-xl p-4 text-center hover:shadow-md hover:border-indigo-300 transition-all group">
            <p class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors">{c.data.name_th}</p>
            <p class="text-xs text-gray-500">{c.data.region_th}</p>
          </a>
        ))}
        <a href="/city/online/" class="block bg-indigo-50 border border-indigo-200 rounded-xl p-4 text-center hover:shadow-md hover:border-indigo-400 transition-all group">
          <p class="font-semibold text-indigo-700">🌐 ออนไลน์</p>
          <p class="text-xs text-indigo-600">ทั่วประเทศ</p>
        </a>
      </div>
    </section>

    <PricingHeatmap />

    <!-- Pillar articles -->
    {pillars.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">บทความและคู่มือเตรียมสอบ</h2>
        <p class="text-gray-600 mb-6">เนื้อหายาวเกี่ยวกับการเลือกติวเตอร์ การวางแผนเตรียมสอบ และค่าใช้จ่าย</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {pillars.map((p) => (
            <a href={`/pillars/${p.id}/`} class="block bg-white border border-gray-200 rounded-xl p-5 hover:shadow-md hover:border-indigo-300 transition-all group">
              <h3 class="font-bold text-gray-900 group-hover:text-indigo-600 transition-colors mb-2 line-clamp-2">{p.data.title}</h3>
              <p class="text-sm text-gray-600 leading-relaxed line-clamp-3">{p.data.description}</p>
              <p class="text-xs text-indigo-600 mt-3">อ่านต่อ &rarr;</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <NewsletterSignup variant="inline" />

    <FAQSection items={homeFaq} />

    <!-- For tutors CTA -->
    <section class="my-16 bg-gradient-to-r from-amber-400 to-orange-500 rounded-2xl p-8 md:p-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-amber-900 mb-3">เป็นเจ้าของสถาบันหรือติวเตอร์?</h2>
      <p class="text-amber-900/85 mb-6 max-w-2xl mx-auto">เพิ่มสถาบันของคุณบนติดฝันฟรี เข้าถึงผู้ปกครองที่กำลังหาที่ติว ทุกระดับชั้นทุกพื้นที่</p>
      <a href="/claim/" class="inline-block bg-white text-amber-900 font-bold px-8 py-3.5 rounded-xl hover:bg-gray-50 transition-all shadow-lg">
        เพิ่มสถาบันของคุณ ฟรี &rarr;
      </a>
    </section>
  </div>
</BaseLayout>
