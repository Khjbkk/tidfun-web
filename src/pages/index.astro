---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSection from '../components/FAQSection.astro';
import { getCollection } from 'astro:content';

const allBlogPosts = await getCollection('blog', ({ data }) => !data.draft && data.publishDate <= new Date());
const latestPosts = allBlogPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const levelCards = [
  {
    level: 'ป.1',
    href: '/exams/por1/',
    accent: 'por1',
    emoji: '🌱',
    description: 'ข้อสอบเข้าสาธิตจุฬา สาธิตเกษตร และโรงเรียนชั้นนำ',
    subjects: ['เชาว์ปัญญา', 'ภาษาไทย', 'คณิตศาสตร์', 'ภาษาอังกฤษ'],
  },
  {
    level: 'ม.1',
    href: '/exams/mor1/',
    accent: 'mor1',
    emoji: '📘',
    description: 'ข้อสอบเข้า ร.ร.ชั้นนำ สาธิตปทุมวัน สวนกุหลาบ เตรียมอุดมพัฒนาการ',
    subjects: ['คณิตศาสตร์', 'วิทยาศาสตร์', 'ภาษาอังกฤษ', 'ภาษาไทย', 'สังคม'],
  },
  {
    level: 'ม.4',
    href: '/exams/mor4/',
    accent: 'mor4',
    emoji: '🎓',
    description: 'ข้อสอบเข้าเตรียมอุดม มหิดลวิทยานุสรณ์ สาธิตจุฬา',
    subjects: ['คณิตศาสตร์', 'วิทยาศาสตร์', 'ภาษาอังกฤษ', 'ภาษาไทย-สังคม'],
  },
];

const uspItems = [
  {
    icon: '📝',
    title: 'ข้อสอบจากสนามจริง',
    desc: 'รวบรวมแนวข้อสอบจากสนามสอบจริง ไม่ใช่ข้อสอบที่แต่งขึ้นเอง',
  },
  {
    icon: '✅',
    title: 'เฉลยละเอียดทุกข้อ',
    desc: 'ทุกข้อมีเฉลยพร้อมวิธีคิดแบบ step-by-step เข้าใจง่าย',
  },
  {
    icon: '🔄',
    title: 'อัปเดตตามหลักสูตรล่าสุด',
    desc: 'ข้อสอบอัปเดตตามหลักสูตรและแนวข้อสอบล่าสุดทุกปี',
  },
  {
    icon: '🔁',
    title: 'ออกแบบให้ฝึกซ้ำได้',
    desc: 'จัดเรียงข้อสอบเป็นชุด ฝึกทำซ้ำหลายรอบเพื่อความชำนาญ',
  },
];

const faqItems = [
  {
    question: 'SheetSmith ต่างจากข้อสอบตามท้องตลาดอย่างไร?',
    answer: 'SheetSmith ต่างจากข้อสอบทั่วไปใน 3 ประเด็นหลัก ประเด็นแรกคือแหล่งที่มา — เรารวบรวมแนวข้อสอบจากสนามสอบจริงของโรงเรียนสาธิตและโรงเรียนชั้นนำ ไม่ใช่ข้อสอบที่แต่งขึ้นเองโดยไม่อ้างอิงสนามจริง ประเด็นที่สองคือเฉลยแบบติวเตอร์ — ทุกข้ออธิบายวิธีคิดแบบ step-by-step เช่น เริ่มจากการอ่านโจทย์ว่าถามอะไร แล้วใช้สูตรอะไรเพราะอะไร ไม่ใช่แค่ระบุคำตอบสุดท้าย ทำให้นักเรียนนำหลักการไปใช้กับข้อสอบลักษณะเดียวกันได้ ประเด็นที่สามคืออัปเดตตามหลักสูตรปัจจุบัน — เราติดตามการเปลี่ยนแปลงของแนวข้อสอบทุกปี ปรับปรุงเนื้อหาให้สอดคล้องกับสิ่งที่โรงเรียนออกล่าสุด เพื่อให้นักเรียนเตรียมตัวกับสิ่งที่จะเจอจริง ไม่ใช่ข้อสอบจากหลายปีก่อนที่อาจล้าสมัย',
  },
  {
    question: 'ลูกอายุเท่าไหร่ควรเริ่มฝึกทำข้อสอบ?',
    answer: 'ช่วงเวลาที่เหมาะสมขึ้นอยู่กับระดับที่ลูกจะสอบ สำหรับสอบเข้า ป.1 ของโรงเรียนสาธิต แนะนำเริ่มฝึกตั้งแต่อายุ 5-6 ขวบ หรือประมาณ 6-12 เดือนก่อนวันสอบจริง ระยะแรกเน้นความคุ้นเคยกับรูปแบบข้อสอบ (เชาว์ปัญญา ภาษาไทย คณิตเบื้องต้น) ไม่ต้องเร่งความเร็ว สำหรับสอบเข้า ม.1 ควรเริ่มตั้งแต่ ป.5 เพราะมีเวลาทบทวนเนื้อหา ป.4-ป.6 ทุกวิชา รวมทั้งฝึกข้อสอบเสริมที่ยากกว่าระดับชั้น สำหรับสอบเข้า ม.4 โดยเฉพาะเตรียมอุดมและ MWIT ควรเริ่มตั้งแต่ ม.2-ม.3 เพื่อให้มีเวลาฝึกข้อสอบหลายชุดและทบทวนจุดอ่อน หลักการคือ ยิ่งเริ่มเร็ว ยิ่งมีเวลาวินิจฉัยปัญหาและแก้ไขก่อนสอบจริง ไม่ใช่อัดติวช่วงท้ายอย่างเดียว',
  },
  {
    question: 'ข้อสอบเข้า ป.1 สาธิตจุฬา ยากไหม?',
    answer: 'ข้อสอบเข้าสาธิตจุฬาระดับ ป.1 ไม่ได้ยากในแง่เนื้อหาวิชาการ แต่ยากที่รูปแบบและความคุ้นเคย ข้อสอบเน้นทดสอบความพร้อม เชาว์ปัญญา การจัดประเภท การเปรียบเทียบ และความเข้าใจภาษา ซึ่งเป็นทักษะที่เด็กในวัยนี้ยังพัฒนาไม่เต็มที่ มีทั้งข้อง่ายที่เด็กส่วนใหญ่ทำได้ และข้อยากที่ต้องคิดเป็นขั้นตอน ระดับการแข่งขันอยู่ในกลุ่มที่สูงที่สุดของประเทศ เพราะอัตรารับเข้าน้อยเทียบกับจำนวนผู้สมัคร แต่การฝึกทำข้อสอบตัวอย่างซ้ำๆ ช่วยลดความตื่นเต้นในวันสอบจริงและทำให้เด็กรู้ว่าต้องคิดอย่างไรกับโจทย์แต่ละประเภท เด็กที่เคยเห็นข้อสอบลักษณะเดียวกันมาก่อนจะทำได้รวดเร็วและมั่นใจกว่าเด็กที่เจอเป็นครั้งแรก',
  },
  {
    question: 'มีเฉลยละเอียดไหม?',
    answer: 'ทุกชุดข้อสอบของ SheetSmith มาพร้อมเฉลยละเอียดแบบติวเตอร์ทุกข้อ ไม่ใช่แค่ระบุคำตอบ A/B/C/D หรือเลขผลลัพธ์ แต่อธิบาย 3 ส่วนหลัก ส่วนแรกคือวิธีอ่านโจทย์ — โจทย์ถามอะไร และคำสำคัญที่ต้องจับ ส่วนที่สองคือวิธีคิด — เลือกใช้หลักการหรือสูตรไหน เพราะอะไร และคำนวณทีละขั้น ส่วนที่สามคือเทคนิคหลีกเลี่ยงข้อผิดพลาด — ข้อนี้คนพลาดเพราะอะไร เพื่อให้นักเรียนเรียนรู้จากเฉลย ไม่ใช่แค่ตรวจคำตอบ รูปแบบนี้เหมาะสำหรับทั้งนักเรียนที่ทบทวนด้วยตัวเอง เพราะเห็นวิธีคิดทำให้แก้โจทย์ใหม่ที่คล้ายกันได้ และผู้ปกครองที่อยากช่วยสอนลูกแต่ไม่แน่ใจวิธีอธิบาย เฉลยเขียนแบบที่ผู้ปกครองนำไปอ่านให้ลูกฟังได้เลย',
  },
  {
    question: 'สั่งซื้อยังไง ได้รับเมื่อไหร่?',
    answer: 'การสั่งซื้อ SheetSmith ใช้ขั้นตอนสั้นๆ ผ่านช่องทาง LINE @sheetsmith หรือ Facebook Page: SheetSmith ขั้นที่หนึ่ง ทักทายและแจ้งระดับ (ป.1, ม.1 หรือ ม.4) พร้อมโรงเรียนหรือวิชาที่สนใจ ขั้นที่สอง ทีมงานจะแนะนำชุดที่ตรงกับเป้าหมายและส่งรายละเอียดราคาให้พิจารณา ขั้นที่สาม ชำระเงินโดยโอนผ่านบัญชีธนาคารที่แจ้ง ขั้นที่สี่ เราส่งลิงก์ดาวน์โหลดไฟล์ PDF ให้ภายในไม่กี่นาทีหลังยืนยันการชำระเงิน ไม่มีการจัดส่งทางกายภาพ ไม่ต้องรอหลายวัน เปิดดูได้ทั้งบนคอมพิวเตอร์ แท็บเล็ต และมือถือ พิมพ์ออกมาทำเป็นกระดาษได้ ทีมงานยินดีตอบคำถามเกี่ยวกับเฉลยหรือเนื้อหาแม้สั่งซื้อไปแล้ว เพราะเราไม่ทิ้งลูกค้าหลังขาย',
  },
];
---

<BaseLayout
  title="หน้าแรก"
  description="SheetSmith ชีทติวสอบเข้า ป.1 ม.1 ม.4 โรงเรียนสาธิตและโรงเรียนชั้นนำ พร้อมเฉลยละเอียด รวมแนวข้อสอบจริงอัปเดตล่าสุด ดาวน์โหลด PDF ได้ทันที"
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-primary py-20 md:py-28">
    <!-- Decorative elements -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute -top-20 -right-20 w-96 h-96 rounded-full bg-secondary"></div>
      <div class="absolute -bottom-32 -left-16 w-80 h-80 rounded-full bg-accent"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="flex-1 text-center md:text-left">
          <p class="text-secondary font-semibold text-sm tracking-widest uppercase mb-4 animate-fade-up">ชีทติวสอบ ประถม-มัธยม</p>
          <h1 class="font-heading text-3xl md:text-5xl font-extrabold text-white mb-5 leading-[1.2] animate-fade-up stagger-1">
            เตรียมสอบเข้า<br />
            <span class="text-secondary">ป.1 ม.1 ม.4</span><br />
            ด้วยข้อสอบจากสนามจริง
          </h1>
          <p class="text-lg text-white/75 max-w-xl mb-8 animate-fade-up stagger-2">
            รวมแนวข้อสอบจากโรงเรียนสาธิตและโรงเรียนชั้นนำ พร้อมเฉลยละเอียดทุกข้อ ดาวน์โหลด PDF ได้ทันที
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start animate-fade-up stagger-3">
            <a
              href="/exams/"
              class="inline-block bg-secondary text-primary-dark font-bold px-8 py-4 rounded-xl text-lg hover:bg-secondary-dark hover:text-white transition-all shadow-lg"
            >
              ดูตัวอย่างข้อสอบฟรี
            </a>
            <a
              href="/about/"
              class="inline-block bg-white/10 backdrop-blur text-white font-semibold px-8 py-4 rounded-xl text-lg hover:bg-white/20 transition-all border border-white/20"
            >
              เกี่ยวกับเรา
            </a>
          </div>
        </div>
        <div class="flex-shrink-0 animate-scale-in stagger-2">
          <img src="/logo.png" alt="SheetSmith Logo" width="200" height="200" class="rounded-2xl shadow-2xl" />
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Stats Bar -->
  <section class="bg-white border-b border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="font-heading text-3xl font-extrabold text-primary">500+</div>
          <div class="text-sm text-text-muted mt-1">ข้อสอบตัวอย่าง</div>
        </div>
        <div>
          <div class="font-heading text-3xl font-extrabold text-accent">3</div>
          <div class="text-sm text-text-muted mt-1">ระดับชั้น</div>
        </div>
        <div>
          <div class="font-heading text-3xl font-extrabold text-secondary">10+</div>
          <div class="text-sm text-text-muted mt-1">วิชาที่ครอบคลุม</div>
        </div>
        <div>
          <div class="font-heading text-3xl font-extrabold text-por1">100%</div>
          <div class="text-sm text-text-muted mt-1">เฉลยละเอียด</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Level Cards Section -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-20">
    <div class="text-center mb-12">
      <p class="text-secondary font-semibold text-sm tracking-widest uppercase mb-2">เลือกระดับชั้น</p>
      <h2 class="font-heading text-2xl md:text-4xl font-bold text-text">
        เตรียมพร้อมสำหรับทุกสนามสอบ
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {levelCards.map((card, i) => (
        <a href={card.href} class={`group block animate-fade-up stagger-${i + 1}`}>
          <div class={`rounded-2xl border-2 border-${card.accent}/30 bg-${card.accent}-light/30 p-7 hover:shadow-xl hover:border-${card.accent} hover:-translate-y-1 transition-all duration-300`}>
            <div class="flex items-center gap-3 mb-4">
              <span class="text-3xl">{card.emoji}</span>
              <div class={`px-3 py-1 rounded-full bg-${card.accent} text-white font-bold text-sm`}>
                {card.level}
              </div>
            </div>
            <h3 class="font-heading text-xl font-bold text-text mb-2 group-hover:text-primary transition-colors">
              สอบเข้า {card.level}
            </h3>
            <p class="text-sm text-text-light mb-5 leading-relaxed">{card.description}</p>
            <div class="flex flex-wrap gap-2">
              {card.subjects.map((subject) => (
                <span class="px-2.5 py-1 bg-white/80 text-text-light text-xs rounded-full border border-border">{subject}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- USP Section -->
  <section class="bg-bg-warm py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <p class="text-secondary font-semibold text-sm tracking-widest uppercase mb-2">จุดเด่น</p>
        <h2 class="font-heading text-2xl md:text-4xl font-bold text-text">
          ทำไมต้อง SheetSmith?
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {uspItems.map((item, i) => (
          <div class={`bg-white rounded-2xl p-7 border border-border hover:shadow-lg hover:-translate-y-1 transition-all duration-300 animate-fade-up stagger-${i + 1}`}>
            <div class="text-3xl mb-4">{item.icon}</div>
            <h3 class="font-heading font-bold text-text mb-2">{item.title}</h3>
            <p class="text-sm text-text-light leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts -->
  {latestPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-20">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-secondary font-semibold text-sm tracking-widest uppercase mb-2">บทความ</p>
          <h2 class="font-heading text-2xl md:text-3xl font-bold text-text">บทความล่าสุด</h2>
        </div>
        <a href="/blog/" class="text-primary hover:text-primary-dark font-semibold text-sm transition-colors hidden sm:block">
          ดูทั้งหมด &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {latestPosts.map((post, i) => (
          <a href={`/blog/${post.id}/`} class={`group block animate-fade-up stagger-${i + 1}`}>
            <div class="bg-white border border-border rounded-2xl p-6 hover:shadow-lg hover:border-primary/30 hover:-translate-y-1 transition-all duration-300 h-full">
              <time class="text-xs text-text-muted font-medium" datetime={post.data.publishDate.toISOString()}>
                {post.data.publishDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h3 class="font-heading font-bold text-text group-hover:text-primary transition-colors mt-3 mb-2 text-lg leading-snug">
                {post.data.title}
              </h3>
              <p class="text-sm text-text-light line-clamp-2 leading-relaxed">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8 sm:hidden">
        <a href="/blog/" class="text-primary font-semibold">ดูบทความทั้งหมด &rarr;</a>
      </div>
    </section>
  )}

  <!-- FAQ Section -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <FAQSection items={faqItems} />
  </div>

  <!-- CTA Section -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <div class="bg-gradient-to-br from-primary to-primary-dark rounded-3xl p-10 md:p-14 text-center text-white relative overflow-hidden">
      <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-secondary/20"></div>
      <div class="absolute -bottom-10 -left-10 w-32 h-32 rounded-full bg-accent/20"></div>
      <div class="relative">
        <h2 class="font-heading text-2xl md:text-3xl font-bold mb-3">พร้อมเริ่มฝึกทำข้อสอบแล้วหรือยัง?</h2>
        <p class="text-white/75 mb-8 max-w-2xl mx-auto">ดาวน์โหลดตัวอย่างข้อสอบฟรี พร้อมเฉลยละเอียดทุกข้อ เริ่มเตรียมตัวได้เลยวันนี้</p>
        <a
          href="/exams/"
          class="inline-block bg-secondary text-primary-dark font-bold px-10 py-4 rounded-xl text-lg hover:bg-secondary-dark hover:text-white transition-all shadow-lg"
        >
          ดูตัวอย่างข้อสอบฟรี
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
