---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  updatedDate?: Date;
  noindex?: boolean;
}

const props = Astro.props;

// Organization schema — ติดฝัน operated by บริษัท ซิโอร่า จำกัด
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ติดฝัน',
  alternateName: ['TidFun', 'tidfun'],
  legalName: 'บริษัท ซิโอร่า จำกัด',
  url: Astro.site?.toString(),
  description: 'Directory แห่งสถาบันกวดวิชาและติวเตอร์ทั่วประเทศไทย เตรียมสอบเข้า ป.1 ม.1 ม.4 มหาวิทยาลัย',
  areaServed: { '@type': 'Country', name: 'Thailand' },
  knowsAbout: [
    'การเตรียมสอบเข้าโรงเรียนสาธิต',
    'การเตรียมสอบเข้าโรงเรียนชั้นนำ',
    'การเตรียมสอบเข้ามหาวิทยาลัย',
    'สถาบันกวดวิชา',
    'ติวเตอร์',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'info@tidfun.com',
    contactType: 'customer service',
    availableLanguage: ['Thai', 'English'],
  },
};

// WebSite schema — enables sitelinks search box
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ติดฝัน',
  url: Astro.site?.toString(),
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${Astro.site?.toString().replace(/\/$/, '')}/search?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};
---

<!DOCTYPE html>
<html lang="th">
  <head>
    <SEOHead {...props} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <!-- Google Analytics (GA4) — replace measurement ID after creating new GA4 property for ติดฝัน.com -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-W0ND9TWZX6"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-W0ND9TWZX6');
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
