---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  updatedDate?: Date;
  noindex?: boolean;
}

const props = Astro.props;

// Organization schema — ติดฝัน operated by บริษัท ซิโอร่า จำกัด
// Editor entity (collective author) for E-E-A-T — ทีมงานติดฝัน is the named
// author/editor team for pillar articles and curation decisions
const editorSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${Astro.site?.toString()}#editorial-team`,
  name: 'ทีมงานติดฝัน',
  alternateName: 'TidFun Editorial Team',
  description: 'ทีมบรรณาธิการของติดฝัน รวบรวม ตรวจสอบ และเขียนเนื้อหาเกี่ยวกับการเตรียมสอบเข้าโรงเรียนและมหาวิทยาลัยในประเทศไทย ทำงานภายใต้บริษัท ซิโอร่า จำกัด',
  parentOrganization: { '@id': `${Astro.site?.toString()}#org` },
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${Astro.site?.toString()}#org`,
  name: 'ติดฝัน',
  alternateName: ['TidFun', 'tidfun'],
  legalName: 'บริษัท ซิโอร่า จำกัด',
  url: Astro.site?.toString(),
  logo: {
    '@type': 'ImageObject',
    url: `${Astro.site?.toString()}logo.png`,
    caption: 'ติดฝัน — TidFun',
  },
  image: `${Astro.site?.toString()}logo.png`,
  slogan: 'ติวที่ใช่ใน 3 นาที',
  foundingDate: '2026',
  description: 'Directory แห่งสถาบันกวดวิชาและติวเตอร์ทั่วประเทศไทย เตรียมสอบเข้า ป.1 ม.1 ม.4 มหาวิทยาลัย',
  areaServed: { '@type': 'Country', name: 'Thailand' },
  knowsAbout: [
    'การเตรียมสอบเข้าโรงเรียนสาธิต',
    'การเตรียมสอบเข้าโรงเรียนชั้นนำ',
    'การเตรียมสอบเข้ามหาวิทยาลัย',
    'สถาบันกวดวิชา',
    'ติวเตอร์',
  ],
  employee: { '@id': `${Astro.site?.toString()}#editorial-team` },
  publishingPrinciples: `${Astro.site?.toString()}editorial-standards/`,
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'info@tidfun.com',
    contactType: 'customer service',
    availableLanguage: ['Thai', 'English'],
  },
};

// WebSite schema — enables sitelinks search box
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ติดฝัน',
  url: Astro.site?.toString(),
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${Astro.site?.toString().replace(/\/$/, '')}/search?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};
---

<!DOCTYPE html>
<html lang="th">
  <head>
    <SEOHead {...props} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(editorSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <!-- Google Analytics (GA4) — tidfun.org -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XDRPLD5K65"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XDRPLD5K65');
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
